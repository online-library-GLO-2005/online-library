# This .env is commited because it is a school project and we are only simulating a real project. 
## In a real project, this file should be added to .gitignore and not commited to the repository.

# Media path change here so that it can be easily changed for local development vs Docker.
# Configured now for docker, so it should be MEDIA_DIR=/app/media, but for local development it can be MEDIA_DIR=./media or similar.
MEDIA_DIR=/app/media

# Flask
FLASK_SECRET_KEY=A_VERY_SECRET_KEY_FOR_FLASK_I_WANT_TO_SLEEP_PLEASE_SEND_HELP_THIS_PROJECT_IS_NOT_WORTH_IT
JWT_SECRET_KEY=ANOTHER_VERYYYY_SECRET_KEY_FOR_JWT_THIS_TIME_,_I_WANT_TO_SLEEP_PLEASE_SEND_HELP_THIS_PROJECT_IS_NOT_WORTH_IT
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7
# Put the frontend urls here
CORS_ORIGINS = ["http://localhost:3000", "http://localhost:80"]

# Database
MYSQL_ROOT_PASSWORD=secret      # If we were in a real situation our server would have this, but we devs wouldn't
MYSQL_DATABASE=online_library   ## If changed, change also in 01_init.sql
MYSQL_USER=myuser               ## If changed, change also in 01_init.sql
MYSQL_PASSWORD=mypassword       ## If changed, change also in 01_init.sql
MYSQL_HOST=db                   ## db for Docker, localhost for local development
MYSQL_PORT=3306
